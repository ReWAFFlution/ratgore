<Control xmlns="https://spacestation14.io"
         xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
         VerticalExpand="False"> <PanelContainer StyleClasses="ServerInfoBackground">
        <BoxContainer Orientation="Vertical" Margin="10" SeparationOverride="10">
            <Label Text="ПОДДЕРЖКА ПРОЕКТА" StyleClasses="LabelHeading" HorizontalAlignment="Center" />
            
            <TabContainer Name="DonationTabs" MinHeight="200">
                <BoxContainer Name="TabInfo" Orientation="Vertical" VerticalExpand="True" Margin="5">
                    <ScrollContainer VerticalExpand="True">
                        <RichTextLabel Name="InfoText" />
                    </ScrollContainer>
                </BoxContainer>

                <BoxContainer Name="TabLevels" Orientation="Vertical" VerticalExpand="True" Margin="5" Visible="False">
                    <ScrollContainer VerticalExpand="True">
                        <RichTextLabel Name="LevelsText" />
                    </ScrollContainer>
                    <Button Name="BuyButtonLevels" Text="Поддержать проект" StyleClasses="NovaLobbyButton" Margin="0 5 0 0" />
                </BoxContainer>

                <BoxContainer Name="TabDiscord" Orientation="Vertical" VerticalExpand="True" Margin="5" Visible="False">
                    <ScrollContainer VerticalExpand="True">
                        <RichTextLabel Name="DiscordText" />
                    </ScrollContainer>
                    <BoxContainer Name="DiscordActionContainer" Orientation="Vertical" SeparationOverride="5">
                        <TextureRect Name="DiscordQr" Stretch="KeepCentered" MinSize="150 150" Visible="False" />
                        <Button Name="DiscordAuthButton" Text="Привязать Дискорд" StyleClasses="NovaLobbyButton" />
                    </BoxContainer>
                </BoxContainer>
            </TabContainer>
        </BoxContainer>
    </PanelContainer>
</Control>